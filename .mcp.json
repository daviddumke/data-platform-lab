{
  "mcpServers": {
    "jira": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "${MCP_JIRA_URL}",
        "JIRA_USERNAME": "${MCP_JIRA_USERNAME}",
        "JIRA_API_TOKEN": "${MCP_JIRA_API_TOKEN}"
      }
    },
    "bigquery": {
      "command": "npx",
      "args": [
        "-y", "@ergut/mcp-bigquery-server",
        "--project-id", "${MCP_BIGQUERY_PROJECT}",
        "--location", "southamerica-east1"
      ]
    }
  }
}
